  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 142b6e4d74f64d63868834ad56940192, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DefaultNamespace.npcs.functions.InformerService
  availableInfos:
  - name: The Forgotten Grave
    quickDescription: The location of a burial site erased from all living memory
    content: Beneath the old oak tree in northern cemetery lies an unmarked grave.
      The soul buried there was wrongfully executed and cannot rest. Disturbing the
      grave will awaken its spirit - but it holds a silver locket containing the
      name of the true killer
    price: 30
  - name: The Hour of Weakness
    quickDescription: A secret known only to those who have crossed to the other
      side
    content: Every night, when the church bell strikes three, the veil between the
      living and the dedad grows thin. During that single minute, spirits can be
      compelled to speak the truth and cannot lie or flee. Use this window wisely
      - ask your question before the last echo fades.
    price: 45
