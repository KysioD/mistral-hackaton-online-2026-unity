  m_Script: {fileID: 11500000, guid: 142b6e4d74f64d63868834ad56940192, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DefaultNamespace.npcs.functions.InformerService
  availableInfos:
  - name: Bandit camp location
    quickDescription: A rough map showing where the local bandits have set up their
      hideout
    content: The bandits have made camp three miles east of the town, hidden within
      the Darkwood forest. They guard a cache of stolen goods and number around a
      dozen men. Their patrol changes at midnight.
    price: 20
  - name: Dragon's weakness
    quickDescription: Whispered knowledge about how to defeat the dragon terrorizing
      the northern vollages
    content: The dragon Vaelthorn has a cracked scale beneath his left wing, exposed
      from an old battle wound. A well aimed arrow or blade to that spot bypasses
      his natural armor entirely. He also fears the smell of sulfur root, which can
      be used as a distraction.
    price: 50
