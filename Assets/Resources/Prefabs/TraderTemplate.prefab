  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DefaultNamespace.npcs.functions.SellerService
  availableItems:
  - Name: Iron Sword
    Description: A sturdy blade forged from quality iron, reliable in close combat.
    Price: 15
  - Name: Leather Armor
    Description: Light weight armor made from tanned hide, offering decent protection
      without hindering movement.
    Price: 25
  - Name: Enchanted Lantern
    Description: A magical lantern that never runs out of oil and illuminates even
      the darkest dungeons.
    Price: 40
--- !u!114 &6011915429246227230
MonoBehaviour:
  m_ObjectHideFlags: 0
